import { context } from '@opentelemetry/api';
import { getNodeAutoInstrumentations } from '@opentelemetry/auto-instrumentations-node';
import { AsyncHooksContextManager } from '@opentelemetry/context-async-hooks';
import { ExpressInstrumentation } from '@opentelemetry/instrumentation-express';
import { B3Propagator } from '@opentelemetry/propagator-b3';
import { resourceFromAttributes } from '@opentelemetry/resources';
import {
  BatchLogRecordProcessor,
  type LogRecordProcessor,
} from '@opentelemetry/sdk-logs';
import { PeriodicExportingMetricReader } from '@opentelemetry/sdk-metrics';
import { api, NodeSDK } from '@opentelemetry/sdk-node';
import {
  BatchSpanProcessor,
  SimpleSpanProcessor,
} from '@opentelemetry/sdk-trace-base';
import { ATTR_SERVICE_NAME } from '@opentelemetry/semantic-conventions';
import * as GrpcExporter from './grpc-exporter';
import * as HttpExporter from './http-exporter';

const GLOBAL_SDK_KEY = '__{{SERVICE_NAME}}_otel_sdk__';

function getSdk(): NodeSDK | undefined {
  return (globalThis as any)[GLOBAL_SDK_KEY];
}

function setSdk(sdk: NodeSDK | undefined): void {
  (globalThis as any)[GLOBAL_SDK_KEY] = sdk;
}

function startTracer(serviceName?: string): void {
  if (getSdk()) return;

  const name = serviceName ?? process.env.OTEL_SERVICE_NAME ?? process.env.npm_package_name;

  const exporterEnv = (process.env.OTEL_EXPORTER || '').toLowerCase();

  console.log(`[OTEL] OTEL_EXPORTER=${exporterEnv || 'unset'} -> Protocolo selecionado: ${exporterEnv === 'grpc' ? 'grpc' : 'http'} \n
    [OTEL] OTEL_EXPORTER_OTLP_ENDPOINT_GRPC=${process.env.OTEL_EXPORTER_OTLP_ENDPOINT_GRPC || 'unset'} \n
    [OTEL] OTEL_EXPORTER_OTLP_ENDPOINT_HTTP=${process.env.OTEL_EXPORTER_OTLP_ENDPOINT_HTTP || 'unset'}`);

  let TraceExporterCtor: any;
  let MetricExporterCtor: any;
  let LogExporterCtor: any;
  let traceExporterUrl: string;
  let metricExporterUrl: string;
  let logExporterUrl: string;

  if (exporterEnv === 'grpc') {
    TraceExporterCtor = GrpcExporter.GrpcTraceExporterCtor;
    MetricExporterCtor = GrpcExporter.GrpcMetricExporterCtor;
    LogExporterCtor = GrpcExporter.GrpcLogExporterCtor;
    traceExporterUrl = GrpcExporter.grpcTraceExporterUrl;
    metricExporterUrl = GrpcExporter.grpcMetricExporterUrl;
    logExporterUrl = GrpcExporter.grpcLogExporterUrl;
  } else {
    TraceExporterCtor = HttpExporter.HttpTraceExporterCtor;
    MetricExporterCtor = HttpExporter.HttpMetricExporterCtor;
    LogExporterCtor = HttpExporter.HttpLogExporterCtor;
    traceExporterUrl = HttpExporter.httpTraceExporterUrl;
    metricExporterUrl = HttpExporter.httpMetricExporterUrl;
    logExporterUrl = HttpExporter.httpLogExporterUrl;
  }

  const resource = resourceFromAttributes({
    [ATTR_SERVICE_NAME]: name,
  });

  const traceExporter = new TraceExporterCtor({ url: traceExporterUrl });

  const metricExporter = new MetricExporterCtor({ url: metricExporterUrl });
  const metricReader = new PeriodicExportingMetricReader({
    exporter: metricExporter,
    exportIntervalMillis: +(process.env.EXPORT_INTERVAL ?? 10000),
    exportTimeoutMillis: 10000,
  });

  const logExporter = new LogExporterCtor({ url: logExporterUrl });
  const logProcessor: LogRecordProcessor = new BatchLogRecordProcessor(
    logExporter,
    {
      maxQueueSize: 1024,
      maxExportBatchSize: 256,
      scheduledDelayMillis: 10000,
      exportTimeoutMillis: 30000,
    }
  );

  const spanProcessor =
    process.env.NODE_ENV === 'development'
      ? new SimpleSpanProcessor(traceExporter)
      : new BatchSpanProcessor(traceExporter);

  api.propagation.setGlobalPropagator(new B3Propagator());
  const contextManager = new AsyncHooksContextManager().enable();
  context.setGlobalContextManager(contextManager);

  const sdk = new NodeSDK({
    resource,
    traceExporter,
    metricReaders: [metricReader],
    logRecordProcessors: [logProcessor],
    spanProcessors: [spanProcessor],
    instrumentations: [
      getNodeAutoInstrumentations({
        '@opentelemetry/instrumentation-http': {
          ignoreIncomingRequestHook: request => {
            const url = request.url || '';
            return url.includes('/health') || url.includes('/healthcheck');
          },
        },
      }),
      new ExpressInstrumentation(),
    ],
  });

  setSdk(sdk);

  process.on('SIGTERM', async () => {
    await stopTracer();
  });

  sdk.start();
  console.log('[OTEL] Tracing initialized');
}

async function stopTracer(): Promise<void> {
  const sdk = getSdk();
  if (!sdk) return;
  setSdk(undefined);
  try {
    await sdk.shutdown();
    console.log('[OTEL] Observability terminated');
  } catch (err) {
    console.error('[OTEL] Error during shutdown', err);
  }
}

export { startTracer, stopTracer };
